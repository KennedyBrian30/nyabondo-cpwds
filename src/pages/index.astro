---
// src/pages/index.astro
import Layout from "../layouts/Layout.astro";
import ImpactNumbers from "../components/ImpactNumbers.astro";

// ─────────────────────────────────────────────────────────────
// Hero slides — 3 images slide horizontally right-to-left
// Save your WebP files to:
//   /public/images/hero/hero-rehabilitation-therapy.webp
//   /public/images/hero/hero-community-outreach.webp
//   /public/images/hero/hero-corrective-surgery.webp
// ─────────────────────────────────────────────────────────────
const heroSlides = [
  {
    src:     "/images/hero/hero-rehabilitation-therapy.webp",
    alt:     "A therapist guiding a patient through rehabilitation exercises at Nyabondo Centre",
  },
  {
    src:     "/images/hero/hero-community-outreach.webp",
    alt:     "Nyabondo staff conducting a disability awareness and screening outreach in a rural community",
  },
  {
    src:     "/images/hero/hero-corrective-surgery.webp",
    alt:     "Surgeons performing a corrective orthopaedic procedure at Nyabondo Centre",
  },
];

// ─────────────────────────────────────────────────────────────
// Partners — save logos as WebP to /public/images/partners/
// ─────────────────────────────────────────────────────────────
const partners = [
  {
    name: "Christian Blind Mission",
    logo: "/images/partners/christian-blind-mission.webp",
    url:  "https://www.cbm.org",
    desc: "International partner in disability-inclusive development and eye health services.",
  },
  {
    name: "Cheshire Disability Services Kenya",
    logo: "/images/partners/cheshire-disability-services-kenya.webp",
    url:  "https://www.cheshire.or.ke",
    desc: "Partner advancing rights and quality of life for persons with disabilities in Kenya.",
  },
  {
    name: "Ministry of Health",
    logo: "/images/partners/ministry-of-health-kenya.webp",
    url:  "https://www.health.go.ke",
    desc: "National health partner for medical services, clinical standards, and policy.",
  },
  {
    name: "National Fund for the Disabled of Kenya",
    logo: "/images/partners/national-fund-disabled-kenya.webp",
    url:  "https://www.nfdk.go.ke",
    desc: "Government fund supporting rehabilitation and social integration of persons with disabilities.",
  },
  {
    name: "National Council for Persons with Disabilities",
    logo: "/images/partners/national-council-persons-disabilities.webp",
    url:  "https://www.ncpwd.go.ke",
    desc: "Statutory body coordinating disability services and enforcing rights across Kenya.",
  },
  {
    name: "Kenya Conference of Catholic Bishops",
    logo: "/images/partners/kenya-conference-catholic-bishops.webp",
    url:  "https://kccb.or.ke",
    desc: "Faith-based partner supporting the Centre's charitable mission and healthcare outreach.",
  },
  {
    name: "Archdiocese of Kisumu",
    logo: "/images/partners/archdiocese-of-kisumu.webp",
    url:  "https://www.archdioceseofkisumu.org",
    desc: "Diocesan partner providing spiritual direction, community networks, and operational support.",
  },
  {
    name: "Association of Sisterhoods of Kenya",
    logo: "/images/partners/association-of-sisterhoods-kenya.webp",
    url:  "https://www.ask.or.ke",
    desc: "Network of religious sisters supporting healthcare, education, and social welfare.",
  },
  {
    name: "Motivation Charitable Trust",
    logo: "/images/partners/motivation-charitable-trust.webp",
    url:  "https://www.motivation.org.uk",
    desc: "Global partner specialising in appropriate wheelchairs and mobility for the developing world.",
  },
  {
    name: "Stichting Bondo Kids",
    logo: "/images/partners/stichting-bondo-kids.webp",
    url:  "#",
    desc: "Dedicated supporter of children's rehabilitation and welfare programmes at Nyabondo.",
  },
];
---

<Layout title="Nyabondo Centre for Persons with Disabilities - Rising above Disability">

  <!-- ═══════════════════════════════════════
       HERO — horizontal sliding carousel
  ═══════════════════════════════════════ -->
  <section class="hero" id="hero" aria-label="Welcome to Nyabondo Centre">

    <!-- The track slides its entire width leftward -->
    <div class="hero-track" id="heroTrack">
      {heroSlides.map((slide, i) => (
        <div class="hero-slide" data-index={i}>
          <picture>
            <source srcset={slide.src} type="image/webp" />
            <img
              src={slide.src}
              alt={slide.alt}
              loading={i === 0 ? "eager" : "lazy"}
              fetchpriority={i === 0 ? "high" : "auto"}
              decoding={i === 0 ? "sync" : "async"}
              width="1920"
              height="1080"
            />
          </picture>
          <div class="hero-slide-overlay" aria-hidden="true"></div>
        </div>
      ))}
    </div>

    <!-- Content panel — sits above all slides, never moves -->
    <div class="hero-content" aria-live="polite">

      <div class="hero-badge">
        <i class="fas fa-star-of-life" aria-hidden="true"></i>
        Serving Kenya since 1963
      </div>

      <h1 class="hero-title">
        Rising above<br />
        <em class="hero-accent">Disability</em>
      </h1>

      <p class="hero-subtitle">
        Providing quality rehabilitation, corrective surgery, therapy, and assistive
        technology to persons with disabilities across Kenya, with dignity, compassion,
        and a commitment to lasting independence.
      </p>

      <div class="hero-actions">
        <a href="/get-involved/donate" class="btn btn-gold">
          <i class="fas fa-heart" aria-hidden="true"></i>
          Support Our Mission
        </a>
        <a href="/get-involved/volunteer" class="btn btn-white-outline">
          <i class="fas fa-arrow-right" aria-hidden="true"></i>
          Request Services
        </a>
      </div>

      <div class="hero-stats" role="list" aria-label="Key statistics">
        <div class="hero-stat" role="listitem">
          <span class="hero-stat-num" aria-label="Over 60 years">60+</span>
          <span class="hero-stat-label">Years of Service</span>
        </div>
        <div class="hero-stat-divider" aria-hidden="true"></div>
        <div class="hero-stat" role="listitem">
          <span class="hero-stat-num" aria-label="Over 50,000 lives">50K+</span>
          <span class="hero-stat-label">Lives Touched</span>
        </div>
        <div class="hero-stat-divider" aria-hidden="true"></div>
        <div class="hero-stat" role="listitem">
          <span class="hero-stat-num">9</span>
          <span class="hero-stat-label">Core Services</span>
        </div>
      </div>

    </div>

    <!-- Controls -->
    <div class="hero-controls" aria-label="Slideshow controls">

      <button class="hero-arrow hero-arrow--prev" id="heroPrev" aria-label="Previous slide">
        <i class="fas fa-chevron-left" aria-hidden="true"></i>
      </button>
      <button class="hero-arrow hero-arrow--next" id="heroNext" aria-label="Next slide">
        <i class="fas fa-chevron-right" aria-hidden="true"></i>
      </button>

      <div class="hero-dots" role="tablist" aria-label="Slide indicators">
        {heroSlides.map((_, i) => (
          <button
            class={`hero-dot${i === 0 ? " is-active" : ""}`}
            data-index={i}
            role="tab"
            aria-selected={i === 0}
            aria-label={`Go to slide ${i + 1}`}
          ></button>
        ))}
      </div>

      <div class="hero-progress" aria-hidden="true">
        <div class="hero-progress-bar" id="heroProgressBar"></div>
      </div>

    </div>

    <div class="hero-scroll" aria-hidden="true">
      <span class="hero-scroll-label">Scroll</span>
      <i class="fas fa-chevron-down"></i>
    </div>

  </section>


  <!-- ═══════════════════════════
       ABOUT NYABONDO CENTRE
  ═══════════════════════════ -->
  <section class="about-intro" id="about" aria-labelledby="about-heading">
    <div class="container">
      <div class="about-grid">

        <div class="about-left">
          <div class="about-header-block">
            <span class="section-eyebrow">About Nyabondo Centre for the Disabled</span>
            <h2 id="about-heading" class="section-title about-title">
              Six Decades of Healing, Hope and Human Dignity
            </h2>
          </div>
          <div class="about-image-wrap">
            <picture>
              <source srcset="/images/about/about-nyabondo-centre.webp" type="image/webp" />
              <img
                src="/images/about/about-nyabondo-centre.webp"
                alt="A dedicated therapist guides a patient through rehabilitation exercises at Nyabondo Centre"
                loading="lazy" decoding="async" width="800" height="600"
              />
            </picture>
            <div class="about-image-badge" aria-hidden="true">
              <span class="about-image-badge-num">1963</span>
              <span class="about-image-badge-label">Year Founded</span>
            </div>
          </div>
        </div>

        <div class="about-text">
          <p class="about-lead">
            Nyabondo Centre for Persons with Disabilities was established in 1963 by
            the Medical Mission Sisters, responding to a pressing need for specialised
            rehabilitation care in western Kenya. What began as a small orthopaedic
            unit in Sondu has grown into one of Kenya's foremost centres of
            comprehensive rehabilitation, touching the lives of tens of thousands of
            persons with physical, sensory, and developmental disabilities.
          </p>

          <p class="about-body">
            Located in Kisumu County, Nyabondo offers a continuum of care spanning
            community outreach and early identification, corrective surgery,
            physiotherapy, the provision of prosthetics and orthotics, and vocational
            training that enables beneficiaries to live with independence and purpose.
            Rooted in values of integrity, respect, and spirituality, the Centre
            holds the conviction that every person, regardless of ability, holds
            inherent worth and deserves the opportunity to thrive.
          </p>

          <div class="about-values-row" aria-label="Guiding values">
            <div class="about-value">
              <i class="fas fa-shield-heart" aria-hidden="true"></i>
              <span>Integrity</span>
            </div>
            <div class="about-value">
              <i class="fas fa-hands-holding-circle" aria-hidden="true"></i>
              <span>Compassion</span>
            </div>
            <div class="about-value">
              <i class="fas fa-star" aria-hidden="true"></i>
              <span>Excellence</span>
            </div>
            <div class="about-value">
              <i class="fas fa-people-group" aria-hidden="true"></i>
              <span>Inclusion</span>
            </div>
          </div>

          <a href="/about/our-story" class="btn btn-primary-outline">
            Discover Our Full Story
            <i class="fas fa-arrow-right" aria-hidden="true"></i>
          </a>
        </div>

      </div>
    </div>
  </section>


  <!-- ═══════════════════════
       IMPACT NUMBERS
  ═══════════════════════ -->
  <ImpactNumbers />


  <!-- ═══════════════════════
       SERVICES
  ═══════════════════════ -->
  <section class="services" aria-labelledby="services-heading">
    <div class="container">

      <div class="section-header">
        <span class="section-eyebrow">Our Services</span>
        <h2 id="services-heading" class="section-title">
          Comprehensive Rehabilitation Services
        </h2>
        <p class="section-subtitle">
          A holistic continuum of care designed to restore function, build confidence,
          and enable lasting independence for every person we serve.
        </p>
      </div>

      <div class="services-grid">

        <article class="service-card">
          <div class="service-card-img">
            <picture>
              <source srcset="/images/services/service-community-outreach.webp" type="image/webp" />
              <img src="/images/services/service-community-outreach.webp"
                   alt="Nyabondo staff conducting community disability screening and outreach"
                   loading="lazy" decoding="async" width="640" height="380" />
            </picture>
            <div class="service-card-overlay" aria-hidden="true"></div>
            <div class="service-card-icon" aria-hidden="true"><i class="fas fa-map-location-dot"></i></div>
          </div>
          <div class="service-card-body">
            <h3>Community Outreaches</h3>
            <p>We take services directly to the community, conducting early identification,
               awareness campaigns, clinical assessments, and registration of persons
               with disabilities in remote and underserved areas.</p>
            <a href="/services/outreaches" class="service-card-link">
              Learn More <i class="fas fa-arrow-right" aria-hidden="true"></i>
            </a>
          </div>
        </article>

        <article class="service-card">
          <div class="service-card-img">
            <picture>
              <source srcset="/images/services/service-corrective-surgery.webp" type="image/webp" />
              <img src="/images/services/service-corrective-surgery.webp"
                   alt="Surgeons performing a corrective orthopaedic procedure at Nyabondo Centre"
                   loading="lazy" decoding="async" width="640" height="380" />
            </picture>
            <div class="service-card-overlay" aria-hidden="true"></div>
            <div class="service-card-icon" aria-hidden="true"><i class="fas fa-stethoscope"></i></div>
          </div>
          <div class="service-card-body">
            <h3>Corrective Surgeries</h3>
            <p>Skilled orthopaedic and reconstructive procedures including club foot
               correction, cleft lip and palate repair, post-burn contracture release,
               and bone deformity correction restore mobility and improve quality of life.</p>
            <a href="/services/surgeries" class="service-card-link">
              Learn More <i class="fas fa-arrow-right" aria-hidden="true"></i>
            </a>
          </div>
        </article>

        <article class="service-card">
          <div class="service-card-img">
            <picture>
              <source srcset="/images/services/service-therapy.webp" type="image/webp" />
              <img src="/images/services/service-therapy.webp"
                   alt="A physiotherapist working with a child during a therapy session at Nyabondo"
                   loading="lazy" decoding="async" width="640" height="380" />
            </picture>
            <div class="service-card-overlay" aria-hidden="true"></div>
            <div class="service-card-icon" aria-hidden="true"><i class="fas fa-hand-holding-heart"></i></div>
          </div>
          <div class="service-card-body">
            <h3>Therapy Services</h3>
            <p>Individualised physiotherapy and occupational therapy programmes for
               children and adults, focused on restoring movement, strength, and
               functional independence across all stages of recovery.</p>
            <a href="/services/therapy" class="service-card-link">
              Learn More <i class="fas fa-arrow-right" aria-hidden="true"></i>
            </a>
          </div>
        </article>

        <article class="service-card">
          <div class="service-card-img">
            <picture>
              <source srcset="/images/services/service-assistive-devices.webp" type="image/webp" />
              <img src="/images/services/service-assistive-devices.webp"
                   alt="A technician fitting a custom prosthetic limb for a patient"
                   loading="lazy" decoding="async" width="640" height="380" />
            </picture>
            <div class="service-card-overlay" aria-hidden="true"></div>
            <div class="service-card-icon" aria-hidden="true"><i class="fas fa-wheelchair"></i></div>
          </div>
          <div class="service-card-body">
            <h3>Assistive Devices</h3>
            <p>Custom-made prosthetics, orthotics, walking aids, and mobility equipment
               crafted using appropriate technology, ensuring every device is functional,
               affordable, and tailored to the individual's needs.</p>
            <a href="/services/assistive-devices" class="service-card-link">
              Learn More <i class="fas fa-arrow-right" aria-hidden="true"></i>
            </a>
          </div>
        </article>

        <article class="service-card">
          <div class="service-card-img">
            <picture>
              <source srcset="/images/services/service-vocational-training.webp" type="image/webp" />
              <img src="/images/services/service-vocational-training.webp"
                   alt="Young adults with disabilities receiving vocational skills training at Nyabondo"
                   loading="lazy" decoding="async" width="640" height="380" />
            </picture>
            <div class="service-card-overlay" aria-hidden="true"></div>
            <div class="service-card-icon" aria-hidden="true"><i class="fas fa-graduation-cap"></i></div>
          </div>
          <div class="service-card-body">
            <h3>Vocational Training</h3>
            <p>Practical livelihood skills in dressmaking, weaving, hairdressing,
               shoemaking, basket weaving, and computer literacy, equipping
               beneficiaries with the tools to earn, contribute, and thrive independently.</p>
            <a href="/services/vocational-training" class="service-card-link">
              Learn More <i class="fas fa-arrow-right" aria-hidden="true"></i>
            </a>
          </div>
        </article>

        <article class="service-card">
          <div class="service-card-img">
            <picture>
              <source srcset="/images/services/service-longterm-rehabilitation.webp" type="image/webp" />
              <img src="/images/services/service-longterm-rehabilitation.webp"
                   alt="A nurse attending to a child receiving long-term rehabilitation at Nyabondo Centre"
                   loading="lazy" decoding="async" width="640" height="380" />
            </picture>
            <div class="service-card-overlay" aria-hidden="true"></div>
            <div class="service-card-icon" aria-hidden="true"><i class="fas fa-clock-rotate-left"></i></div>
          </div>
          <div class="service-card-body">
            <h3>Long-term Rehabilitation</h3>
            <p>Specialised, programme-based therapy for children and adults with
               cerebral palsy and complex long-term care needs, providing consistent,
               structured support for measurable progress over time.</p>
            <a href="/services/longterm-rehab" class="service-card-link">
              Learn More <i class="fas fa-arrow-right" aria-hidden="true"></i>
            </a>
          </div>
        </article>

        <article class="service-card">
          <div class="service-card-img">
            <picture>
              <source srcset="/images/services/service-inpatient-care.webp" type="image/webp" />
              <img src="/images/services/service-inpatient-care.webp"
                   alt="A patient receiving round-the-clock inpatient care at Nyabondo Centre"
                   loading="lazy" decoding="async" width="640" height="380" />
            </picture>
            <div class="service-card-overlay" aria-hidden="true"></div>
            <div class="service-card-icon" aria-hidden="true"><i class="fas fa-bed-pulse"></i></div>
          </div>
          <div class="service-card-body">
            <h3>Inpatient Services</h3>
            <p>Residential care for patients requiring surgery, intensive rehabilitation,
               or post-operative recovery. Our inpatient ward provides a safe, supportive
               environment with round-the-clock clinical attention and holistic care.</p>
            <a href="/services/inpatient" class="service-card-link">
              Learn More <i class="fas fa-arrow-right" aria-hidden="true"></i>
            </a>
          </div>
        </article>

        <article class="service-card">
          <div class="service-card-img">
            <picture>
              <source srcset="/images/services/service-outpatient-clinic.webp" type="image/webp" />
              <img src="/images/services/service-outpatient-clinic.webp"
                   alt="Patients attending outpatient consultations and follow-up sessions at Nyabondo"
                   loading="lazy" decoding="async" width="640" height="380" />
            </picture>
            <div class="service-card-overlay" aria-hidden="true"></div>
            <div class="service-card-icon" aria-hidden="true"><i class="fas fa-hospital-user"></i></div>
          </div>
          <div class="service-card-body">
            <h3>Outpatient Services</h3>
            <p>Clinical consultations, follow-up care, therapy sessions, and device
               fittings for patients who do not require admission. Our outpatient
               programme ensures continuity of care for hundreds of clients each month.</p>
            <a href="/services/outpatient" class="service-card-link">
              Learn More <i class="fas fa-arrow-right" aria-hidden="true"></i>
            </a>
          </div>
        </article>

        <article class="service-card">
          <div class="service-card-img">
            <picture>
              <source srcset="/images/services/service-preschool-education.webp" type="image/webp" />
              <img src="/images/services/service-preschool-education.webp"
                   alt="Young children with disabilities engaged in early learning activities at Nyabondo"
                   loading="lazy" decoding="async" width="640" height="380" />
            </picture>
            <div class="service-card-overlay" aria-hidden="true"></div>
            <div class="service-card-icon" aria-hidden="true"><i class="fas fa-child-reaching"></i></div>
          </div>
          <div class="service-card-body">
            <h3>Pre-school Education</h3>
            <p>An inclusive early childhood programme for children with disabilities,
               combining stimulation therapy, school-readiness activities, and parental
               guidance to give every child the strongest possible foundation for learning.</p>
            <a href="/services/preschool" class="service-card-link">
              Learn More <i class="fas fa-arrow-right" aria-hidden="true"></i>
            </a>
          </div>
        </article>

      </div>

      <div class="section-cta">
        <a href="/services" class="btn btn-primary">
          View All Services <i class="fas fa-arrow-right" aria-hidden="true"></i>
        </a>
      </div>

    </div>
  </section>


  <!-- ═══════════════════════
       PARTNERS
  ═══════════════════════ -->
  <section class="partners" aria-labelledby="partners-heading">
    <div class="container">

      <div class="section-header">
        <span class="section-eyebrow">Our Partners</span>
        <h2 id="partners-heading" class="section-title">Supported by Trusted Partners</h2>
        <p class="section-subtitle">
          We are grateful for the organisations and institutions that walk alongside us,
          providing support, expertise, and shared commitment to transforming the lives
          of persons with disabilities in Kenya.
        </p>
      </div>

      <div class="partners-grid">
        {partners.map(partner => (
          <a
            href={partner.url}
            target="_blank"
            rel="noopener noreferrer"
            class="partner-card"
            aria-label={`Visit the ${partner.name} website (opens in new tab)`}
          >
            <div class="partner-logo-wrap">
              <picture>
                <source srcset={partner.logo} type="image/webp" />
                <img
                  src={partner.logo}
                  alt={`${partner.name} logo`}
                  loading="lazy"
                  decoding="async"
                  width="160"
                  height="60"
                  onerror="this.closest('picture').style.display='none';this.closest('.partner-logo-wrap').querySelector('.partner-logo-fallback').style.display='flex';"
                />
              </picture>
              <div class="partner-logo-fallback" style="display:none;" aria-hidden="true">
                <i class="fas fa-handshake"></i>
              </div>
            </div>
            <div class="partner-info">
              <span class="partner-name">{partner.name}</span>
              <span class="partner-desc">{partner.desc}</span>
            </div>
            <span class="partner-visit" aria-hidden="true">
              Visit website <i class="fas fa-arrow-up-right-from-square"></i>
            </span>
          </a>
        ))}
      </div>

      <div class="section-cta">
        <a href="/partners" class="btn btn-primary-outline">
          Meet All Our Partners <i class="fas fa-arrow-right" aria-hidden="true"></i>
        </a>
        <a href="/get-involved/partner" class="btn btn-gold">
          Become a Partner <i class="fas fa-handshake" aria-hidden="true"></i>
        </a>
      </div>

    </div>
  </section>


  <!-- ═══════════════════════
       SUCCESS STORIES
  ═══════════════════════ -->
  <section class="stories" aria-labelledby="stories-heading">
    <div class="container">

      <div class="section-header">
        <span class="section-eyebrow">Success Stories</span>
        <h2 id="stories-heading" class="section-title">Lives Transformed</h2>
        <p class="section-subtitle">
          Behind every statistic is a person, a family, a community changed forever.
          Here are just a few of the thousands of stories we carry with us.
        </p>
      </div>

      <div class="stories-grid">

        <article class="story-card">
          <div class="story-img">
            <picture>
              <source srcset="/images/stories/story-sarah-recovery.webp" type="image/webp" />
              <img src="/images/stories/story-sarah-recovery.webp"
                   alt="A young girl smiling and walking confidently after corrective surgery at Nyabondo"
                   loading="lazy" decoding="async" width="640" height="440" />
            </picture>
          </div>
          <div class="story-body">
            <div class="story-stars" aria-label="Five star experience">
              <i class="fas fa-star" aria-hidden="true"></i>
              <i class="fas fa-star" aria-hidden="true"></i>
              <i class="fas fa-star" aria-hidden="true"></i>
              <i class="fas fa-star" aria-hidden="true"></i>
              <i class="fas fa-star" aria-hidden="true"></i>
            </div>
            <h3>Sarah's Journey</h3>
            <blockquote>
              "After her corrective surgery at Nyabondo, Sarah can now walk independently
              and attend school like every other child. She tells us she wants to become
              a doctor someday."
            </blockquote>
            <cite>Mother of Sarah, aged 8</cite>
          </div>
        </article>

        <article class="story-card">
          <div class="story-img">
            <picture>
              <source srcset="/images/stories/story-james-vocational.webp" type="image/webp" />
              <img src="/images/stories/story-james-vocational.webp"
                   alt="A young man confidently working at his computer business after vocational training"
