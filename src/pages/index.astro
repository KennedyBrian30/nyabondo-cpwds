<!-- ═══════════════════════════════════════════════════════════
     HERO CAROUSEL SCRIPT
     Slides translate horizontally (right-to-left) using CSS
     transform on a flex track. Pure vanilla JS, no deps.
     Auto-advances every 6 s. Pauses on hover/focus.
     Touch/swipe + keyboard arrow key support.
     Respects prefers-reduced-motion.
═══════════════════════════════════════════════════════════ -->
<script>
  (() => {
    const DURATION = 6000;   // ms per slide

    const track       = document.getElementById('heroTrack');
    const progressBar = document.getElementById('heroProgressBar');
    const dots        = [...document.querySelectorAll('.hero-dot')];
    const prevBtn     = document.getElementById('heroPrev');
    const nextBtn     = document.getElementById('heroNext');
    const hero        = document.getElementById('hero');

    if (!track) return;

    const slides = [...track.querySelectorAll('.hero-slide')];
    const total  = slides.length;
    if (total < 2) return;

    const reduced = window.matchMedia('(prefers-reduced-motion: reduce)').matches;

    let current   = 0;
    let paused    = false;
    let startTime = null;
    let elapsed   = 0;
    let rafId     = null;

    // ── Position track ──────────────────────────
    function setPosition(index, animate) {
      track.style.transition = (animate && !reduced)
        ? 'transform 700ms cubic-bezier(0.77, 0, 0.175, 1)'
        : 'none';
      track.style.transform  = `translateX(-${index * 100}%)`;
    }

    // ── Update dot indicators ────────────────────
    function updateDots(index) {
      dots.forEach((d, i) => {
        d.classList.toggle('is-active', i === index);
        d.setAttribute('aria-selected', String(i === index));
      });
    }

    // ── Go to slide ──────────────────────────────
    function goTo(index, animate = true) {
      current = ((index % total) + total) % total;
      setPosition(current, animate);
      updateDots(current);
      resetProgress();
    }

    // ── Progress bar ─────────────────────────────
    function resetProgress() {
      cancelAnimationFrame(rafId);
      startTime = null;
      elapsed   = 0;
      if (progressBar) {
        progressBar.style.transition = 'none';
        progressBar.style.width      = '0%';
        // Force reflow
        void progressBar.offsetWidth;
        progressBar.style.transition = `width ${DURATION}ms linear`;
      }
      if (!paused && !reduced) rafId = requestAnimationFrame(tick);
    }

    function tick(ts) {
      if (paused) return;
      if (!startTime) startTime = ts;
      elapsed = ts - startTime;
      const pct = Math.min((elapsed / DURATION) * 100, 100);
      if (progressBar) progressBar.style.width = pct + '%';
      if (elapsed >= DURATION) {
        goTo(current + 1);
      } else {
        rafId = requestAnimationFrame(tick);
      }
    }

    function pause()  { paused = true;  cancelAnimationFrame(rafId); }
    function resume() {
      if (!paused) return;
      paused    = false;
      startTime = performance.now() - elapsed;
      rafId     = requestAnimationFrame(tick);
    }

    // ── Button listeners ──────────────────────────
    prevBtn?.addEventListener('click', () => goTo(current - 1));
    nextBtn?.addEventListener('click', () => goTo(current + 1));
    dots.forEach((dot, i) => dot.addEventListener('click', () => goTo(i)));

    // ── Hover / focus ─────────────────────────────
    hero?.addEventListener('mouseenter', pause);
    hero?.addEventListener('mouseleave', resume);
    hero?.addEventListener('focusin',    pause);
    hero?.addEventListener('focusout',   resume);

    // ── Keyboard ──────────────────────────────────
    hero?.addEventListener('keydown', e => {
      if (e.key === 'ArrowLeft')  goTo(current - 1);
      if (e.key === 'ArrowRight') goTo(current + 1);
    });

    // ── Touch / swipe ─────────────────────────────
    let touchX = 0;
    hero?.addEventListener('touchstart', e => {
      touchX = e.changedTouches[0].clientX;
    }, { passive: true });
    hero?.addEventListener('touchend', e => {
      const dx = e.changedTouches[0].clientX - touchX;
      if (Math.abs(dx) > 48) goTo(current + (dx < 0 ? 1 : -1));
    }, { passive: true });

    // ── Init ──────────────────────────────────────
    setPosition(0, false);
    updateDots(0);
    if (!reduced) rafId = requestAnimationFrame(tick);

  })();
</script>


<style>
  /* ══════════════════════════════
     DESIGN TOKENS
  ══════════════════════════════ */
  :root {
    --primary:         #1B3A6B;
    --primary-dark:    #122952;
    --primary-light:   #2a5298;
    --secondary:       #C8922A;
    --secondary-dark:  #a57419;
    --secondary-light: #e8a93a;
    --text:            #1a1a2e;
    --text-light:      #4a5568;
    --text-muted:      #718096;
    --background:      #fafaf8;
    --border:          #e8e8e0;
    --shadow-sm:       0 1px 3px rgba(0,0,0,0.06);
    --shadow-md:       0 4px 16px rgba(0,0,0,0.08);
    --shadow-lg:       0 10px 40px rgba(0,0,0,0.12);
    --radius-sm:       6px;
    --radius-md:       12px;
    --radius-lg:       20px;
  }

  /* ══════════════════════════════
     UTILITIES
  ══════════════════════════════ */
  .container { max-width: 1200px; margin: 0 auto; padding: 0 24px; }

  .section-header { text-align: center; max-width: 680px; margin: 0 auto 56px; }
  .section-header--light { margin-bottom: 48px; }

  .section-eyebrow {
    display: inline-block; font-size: 0.75rem; font-weight: 700;
